        { "title": "Installation", "path": "/getting-started/installation", "icon": "download" },
        { "title": "Siebel setup (the PR)", "path": "/getting-started/siebel-setup", "icon": "plug" },
        { "title": "Typing your applets", "path": "/getting-started/typing", "icon": "braces" },
        { "title": "Initialising the factory", "path": "/getting-started/init", "icon": "power" },
        { "title": "Quick start", "path": "/getting-started/quick-start", "icon": "zap" }
      ]
    },
    {
      "title": "Guides",
      "icon": "book-open",
      "collapsible": true,
      "children": [
        { "title": "Reading data (list & form)", "path": "/guides/reading-data", "icon": "table" },
        { "title": "Creating records (react-hook-form)", "path": "/guides/creating-records", "icon": "file-plus" },
        { "title": "Updating records", "path": "/guides/updating-records", "icon": "pencil" },
        { "title": "Querying", "path": "/guides/querying", "icon": "search" },
